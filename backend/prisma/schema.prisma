generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  SUPER_ADMIN
  DEPT_ADMIN
  SUBORDINATE
  REQUESTER
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  googleId       String?   @unique @map("google_id")
  name           String
  profilePicture String?   @map("profile_picture")
  roleType       RoleType  @default(REQUESTER) @map("role_type")
  language       String    @default("es")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  departmentUsers    DepartmentUser[]
  ticketAccess       DepartmentTicketAccess[]
  createdDepartments Department[]             @relation("DepartmentCreator")
  sessions           UserSession[]
  auditLogs          AuditLog[]
  requestedTickets   Ticket[]                 @relation("TicketRequester")
  assignedTickets    Ticket[]                 @relation("TicketAssignedTo")
  ticketRatings      TicketRating[]
  ticketMessages     TicketMessage[]
  ticketReads        TicketUserRead[]
  uploadedDeliverables TicketDeliverable[]    @relation("DeliverableUploads")
  reviewedDeliverables TicketDeliverable[]    @relation("DeliverableReviews")
  notifications        Notification[]
  fcmTokens            FcmToken[]
  brandingUpdates      BrandingConfig[]     @relation("BrandingUpdatedBy")

  @@map("users")
}

model Department {
  id                     String    @id @default(uuid())
  name                   String    @unique
  prefix                 String    @unique
  description            String?
  isDefaultForRequesters Boolean   @default(false) @map("is_default_for_requesters")
  requireRating          Boolean   @default(true) @map("require_rating")
  autoCloseAfterDays     Int       @default(8) @map("auto_close_after_days")
  requireDeliverable     Boolean   @default(false) @map("require_deliverable")
  maxDeliverableRejections Int     @default(3) @map("max_deliverable_rejections")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  users         DepartmentUser[]
  ticketAccess  DepartmentTicketAccess[]
  createdBy     User[]                   @relation("DepartmentCreator")
  slaConfigs    DepartmentSLA[]
  workSchedules DepartmentWorkSchedule[]
  forms         TicketForm[]
  tickets       Ticket[]

  @@map("departments")
}

model DepartmentUser {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  userId       String   @map("user_id")
  role         String
  createdAt    DateTime @default(now()) @map("created_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@map("department_users")
}

model DepartmentTicketAccess {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@map("department_ticket_access")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  isActive     Boolean  @default(true) @map("is_active")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  resource     String
  resourceId   String?  @map("resource_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  status       String   @default("success")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// FASE 2: FORMULARIOS DINÁMICOS - SEMANA 6
// Catálogo de Tipos de Campos y SLA
// ============================================

enum FieldCategory {
  TEXT
  NUMBER
  SELECTION
  DATE
  FILE
  ADVANCED
}

enum ValidationType {
  REQUIRED
  MIN_LENGTH
  MAX_LENGTH
  MIN_VALUE
  MAX_VALUE
  PATTERN
  EMAIL
  URL
  PHONE
  CUSTOM
}

enum SLAPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model FieldType {
  id          String        @id @default(uuid())
  name        String        @unique
  label       String
  category    FieldCategory
  description String?
  icon        String?

  hasOptions      Boolean @default(false)
  allowMultiple   Boolean @default(false)
  hasPlaceholder  Boolean @default(true)
  hasDefaultValue Boolean @default(true)

  availableValidations Json?

  componentType String
  inputProps    Json?

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  formFields FormField[]

  @@map("field_types")
}

model ValidationRuleCatalog {
  id          String         @id @default(uuid())
  type        ValidationType @unique
  name        String
  description String?

  requiresValue Boolean @default(false)
  valueType     String?

  defaultErrorMessage String @map("default_error_message")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("validation_rules_catalog")
}

model SLAConfiguration {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  priority    SLAPriority @default(MEDIUM)

  responseTime   Int @map("response_time")
  resolutionTime Int @map("resolution_time")

  escalationEnabled Boolean @default(false) @map("escalation_enabled")
  escalationTime    Int?    @map("escalation_time")

  businessHoursOnly Boolean @default(true) @map("business_hours_only")

  notifyOnBreach Boolean @default(true) @map("notify_on_breach")
  notifyBefore   Int?    @default(30) @map("notify_before")

  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  departments DepartmentSLA[]

  @@map("sla_configurations")
}

model DepartmentSLA {
  id                 String      @id @default(uuid())
  departmentId       String      @map("department_id")
  slaConfigurationId String      @map("sla_configuration_id")
  priority           SLAPriority
  isDefault          Boolean     @default(false) @map("is_default")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  slaConfiguration SLAConfiguration @relation(fields: [slaConfigurationId], references: [id], onDelete: Cascade)

  @@unique([departmentId, priority])
  @@map("department_sla")
}

model DepartmentWorkSchedule {
  id           String  @id @default(uuid())
  departmentId String  @map("department_id")
  dayOfWeek    Int     @map("day_of_week")
  startHour    Int     @map("start_hour")
  startMinute  Int     @default(0) @map("start_minute")
  endHour      Int     @map("end_hour")
  endMinute    Int     @default(0) @map("end_minute")
  isWorkday    Boolean @default(true) @map("is_workday")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, dayOfWeek])
  @@index([departmentId])
  @@map("department_work_schedules")
}

// ============================================
// FASE 3: FORM BUILDER - SEMANA 7
// Formularios personalizados para tickets
// ============================================

enum FormStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model TicketForm {
  id           String     @id @default(uuid())
  departmentId String     @map("department_id")
  name         String
  description  String?
  status       FormStatus @default(DRAFT)
  isDefault    Boolean    @default(false) @map("is_default")
  version      Int        @default(1)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  department Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  fields     FormField[]
  tickets    Ticket[]

  @@index([departmentId])
  @@index([status])
  @@index([departmentId, status])
  @@index([departmentId, isDefault])
  @@map("ticket_forms")
}

model FormField {
  id          String @id @default(uuid())
  formId      String @map("form_id")
  fieldTypeId String @map("field_type_id")

  label       String
  placeholder String?
  helpText    String? @map("help_text")

  isRequired Boolean @default(false) @map("is_required")
  isVisible  Boolean @default(true) @map("is_visible")

  order       Int  @default(0)
  row         Int? @default(0)
  columnInRow Int? @default(0) @map("column_in_row")
  columnSpan  Int? @default(3) @map("column_span")

  defaultValue String? @map("default_value")

  validationRules Json? @map("validation_rules")
  conditionalLogic Json? @map("conditional_logic")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  form      TicketForm    @relation(fields: [formId], references: [id], onDelete: Cascade)
  fieldType FieldType     @relation(fields: [fieldTypeId], references: [id], onDelete: Restrict)
  options   FieldOption[]

  @@index([formId])
  @@index([fieldTypeId])
  @@index([order])
  @@index([formId, order])
  @@index([formId, isVisible])
  @@map("form_fields")
}

model FieldOption {
  id      String @id @default(uuid())
  fieldId String @map("field_id")

  label String
  value String
  order Int    @default(0)

  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  field FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId])
  @@index([fieldId, order])
  @@map("field_options")
}

enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Ticket {
  id           String @id @default(uuid())
  ticketNumber String @unique @map("ticket_number")

  departmentId String  @map("department_id")
  formId       String  @map("form_id")
  requesterId  String  @map("requester_id")
  assignedToId String? @map("assigned_to_id")
  parentTicketId String? @map("parent_ticket_id")

  title    String
  status   TicketStatus   @default(NEW)
  priority TicketPriority @default(MEDIUM)

  formData Json @map("form_data")

  slaDeadline DateTime? @map("sla_deadline")
  slaExceeded Boolean   @default(false) @map("sla_exceeded")
  slaPausedAt DateTime? @map("sla_paused_at")
  slaTotalPausedMinutes Int @default(0) @map("sla_total_paused_minutes")
  slaStartTime DateTime? @map("sla_start_time")
  createdOutsideBusinessHours Boolean @default(false) @map("created_outside_business_hours")

  waitingReason String? @map("waiting_reason") @db.Text

  deliverableRejections Int @default(0) @map("deliverable_rejections")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")
  closedAt   DateTime? @map("closed_at")
  deletedAt  DateTime? @map("deleted_at")

  department Department @relation(fields: [departmentId], references: [id])
  form       TicketForm @relation(fields: [formId], references: [id])
  requester  User       @relation("TicketRequester", fields: [requesterId], references: [id])
  assignedTo User?      @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  parentTicket Ticket?  @relation("TicketFollowUp", fields: [parentTicketId], references: [id])
  childTickets Ticket[] @relation("TicketFollowUp")

  rating   TicketRating?
  messages TicketMessage[]
  userReads TicketUserRead[]
  deliverables TicketDeliverable[]

  @@index([departmentId])
  @@index([formId])
  @@index([requesterId])
  @@index([assignedToId])
  @@index([parentTicketId])
  @@index([status])
  @@index([priority])
  @@index([ticketNumber])
  @@index([createdAt])
  @@index([departmentId, status])
  @@index([assignedToId, status])
  @@index([requesterId, status])
  @@index([slaExceeded])
  @@index([deletedAt])
  @@index([departmentId, createdAt])
  @@index([status, resolvedAt])
  @@map("tickets")
}

model TicketRating {
  id       String @id @default(uuid())
  ticketId String @unique @map("ticket_id")

  rating  Int    @map("rating") // 1-5 estrellas
  comment String? @map("comment") @db.Text

  ratedBy   String   @map("rated_by")
  ratedAt   DateTime @default(now()) @map("rated_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [ratedBy], references: [id])

  @@index([ticketId])
  @@index([ratedBy])
  @@index([rating])
  @@map("ticket_ratings")
}

model TicketMessage {
  id           String   @id @default(uuid())
  ticketId     String   @map("ticket_id")
  userId       String   @map("user_id")
  message      String   @db.Text
  attachmentUrl String?  @map("attachment_url")
  attachmentName String? @map("attachment_name")
  attachmentType String? @map("attachment_type")
  attachmentSize Int?    @map("attachment_size")
  replyToId    String?  @map("reply_to_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ticket  Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])
  replyTo TicketMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies TicketMessage[] @relation("MessageReplies")

  @@index([ticketId])
  @@index([userId])
  @@index([replyToId])
  @@index([createdAt])
  @@map("ticket_messages")
}

model TicketUserRead {
  id            String   @id @default(uuid())
  ticketId      String   @map("ticket_id")
  userId        String   @map("user_id")
  lastReadAt    DateTime @default(now()) @map("last_read_at")
  lastMessageId String?  @map("last_message_id")

  ticket  Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@index([userId])
  @@index([ticketId])
  @@map("ticket_user_reads")
}

enum DeliverableStatus {
  PENDING
  APPROVED
  REJECTED
}

model TicketDeliverable {
  id              String             @id @default(uuid())
  ticketId        String             @map("ticket_id")
  uploadedById    String             @map("uploaded_by_id")
  fileUrl         String             @map("file_url")
  fileName        String             @map("file_name")
  fileSize        Int                @map("file_size")
  fileType        String             @map("file_type")
  status          DeliverableStatus  @default(PENDING)
  rejectionReason String?            @map("rejection_reason") @db.Text
  reviewedById    String?            @map("reviewed_by_id")
  reviewedAt      DateTime?          @map("reviewed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  ticket       Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User   @relation("DeliverableUploads", fields: [uploadedById], references: [id])
  reviewedBy   User?  @relation("DeliverableReviews", fields: [reviewedById], references: [id])

  @@index([ticketId])
  @@index([uploadedById])
  @@index([status])
  @@index([ticketId, status])
  @@map("ticket_deliverables")
}

// ============================================
// FASE 4: NOTIFICACIONES - SEMANA 18
// Sistema de notificaciones, emails y push
// ============================================

enum NotificationType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_STATUS_CHANGED
  TICKET_PRIORITY_CHANGED
  TICKET_RESOLVED
  TICKET_CLOSED
  TICKET_REOPENED
  TICKET_CANCELLED
  TICKET_AUTO_CLOSED
  TICKET_RATED
  DELIVERABLE_UPLOADED
  DELIVERABLE_APPROVED
  DELIVERABLE_REJECTED
  DELIVERABLE_LIMIT_EXCEEDED
  SLA_WARNING
  SLA_EXCEEDED
  NEW_MESSAGE
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  data      Json?            // ticketId, ticketNumber, etc.
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

model EmailTemplate {
  id          String   @id @default(uuid())
  code        String   @unique // TICKET_CREATED, TICKET_ASSIGNED, etc.
  name        String
  subject     String
  htmlBody    String   @map("html_body") @db.Text
  textBody    String?  @map("text_body") @db.Text
  variables   Json?    // Lista de variables disponibles: ["ticket_number", "user_name", ...]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  device    String?  // web, android, ios
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("fcm_tokens")
}

model BrandingConfig {
  id                String   @id @default(uuid())
  // Logo
  logoUrl           String?  @map("logo_url")
  logoSmallUrl      String?  @map("logo_small_url")
  appName           String   @default("SCOT") @map("app_name")
  // Colores primarios (hex)
  primaryColor      String   @default("#9333ea") @map("primary_color")
  secondaryColor    String   @default("#2563eb") @map("secondary_color")
  // Sidebar
  sidebarBgColor    String   @default("#ffffff") @map("sidebar_bg_color")
  sidebarTextColor  String   @default("#4b5563") @map("sidebar_text_color")
  // Login
  loginBgType       String   @default("gradient") @map("login_bg_type") // "gradient" | "image" | "color"
  loginBgValue      String   @default("from-slate-900 via-purple-900 to-slate-900") @map("login_bg_value")
  loginBgImageUrl   String?  @map("login_bg_image_url")
  // Meta
  isActive          Boolean  @default(true) @map("is_active")
  updatedBy         String?  @map("updated_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  updatedByUser User? @relation("BrandingUpdatedBy", fields: [updatedBy], references: [id])

  @@map("branding_configs")
}
