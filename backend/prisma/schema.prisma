generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  SUPER_ADMIN
  DEPT_ADMIN
  SUBORDINATE
  REQUESTER
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  googleId       String?  @unique @map("google_id")
  name           String
  profilePicture String?  @map("profile_picture")
  roleType       RoleType @default(REQUESTER) @map("role_type")
  language       String   @default("es")
  isActive       Boolean  @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  // Nueva relación directa con departamento
  departmentId   String?  @map("department_id")
  departmentRole String?  @default("MEMBER") @map("department_role") // ADMIN o MEMBER

  department         Department? @relation("UserDepartment", fields: [departmentId], references: [id])
  departmentUsers    DepartmentUser[] // Mantener temporalmente para migración
  createdDepartments Department[] @relation("DepartmentCreator")
  sessions           UserSession[]
  auditLogs          AuditLog[]

  @@index([departmentId])
  @@map("users")
}

model Department {
  id                      String   @id @default(uuid())
  name                    String
  prefix                  String   @unique
  description             String?
  isDefaultForRequesters  Boolean  @default(false) @map("is_default_for_requesters")
  createdById             String?  @map("created_by")
  deletedAt               DateTime? @map("deleted_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  createdBy       User?   @relation("DepartmentCreator", fields: [createdById], references: [id])
  users           User[]  @relation("UserDepartment") // Nueva relación directa
  departmentUsers DepartmentUser[] // Mantener temporalmente para migración

  @@map("departments")
}

model DepartmentUser {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  userId       String   @map("user_id")
  role         String
  createdAt    DateTime @default(now()) @map("created_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@map("department_users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  isActive     Boolean  @default(true) @map("is_active")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  resource    String
  resourceId  String?  @map("resource_id")
  details     Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  status      String   @default("success")
  errorMessage String? @map("error_message")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
