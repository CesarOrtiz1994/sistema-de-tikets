generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleType {
  SUPER_ADMIN
  DEPT_ADMIN
  SUBORDINATE
  REQUESTER
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  googleId       String?   @unique @map("google_id")
  name           String
  profilePicture String?   @map("profile_picture")
  roleType       RoleType  @default(REQUESTER) @map("role_type")
  language       String    @default("es")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Nueva relación directa con departamento
  departmentId   String? @map("department_id")
  departmentRole String? @default("MEMBER") @map("department_role") // ADMIN o MEMBER

  department         Department?      @relation("UserDepartment", fields: [departmentId], references: [id])
  departmentUsers    DepartmentUser[] // Mantener temporalmente para migración
  createdDepartments Department[]     @relation("DepartmentCreator")
  sessions           UserSession[]
  auditLogs          AuditLog[]

  @@index([departmentId])
  @@map("users")
}

model Department {
  id                     String    @id @default(uuid())
  name                   String    @unique
  prefix                 String    @unique
  description            String?
  isDefaultForRequesters Boolean   @default(false) @map("is_default_for_requesters")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  users      DepartmentUser[]
  members    User[]           @relation("UserDepartment")
  createdBy  User[]           @relation("DepartmentCreator")
  slaConfigs DepartmentSLA[]

  @@map("departments")
}

model DepartmentUser {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  userId       String   @map("user_id")
  role         String
  createdAt    DateTime @default(now()) @map("created_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@map("department_users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  isActive     Boolean  @default(true) @map("is_active")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("user_sessions")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  resource     String
  resourceId   String?  @map("resource_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  status       String   @default("success")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// FASE 2: FORMULARIOS DINÁMICOS - SEMANA 6
// Catálogo de Tipos de Campos y SLA
// ============================================

enum FieldCategory {
  TEXT
  NUMBER
  SELECTION
  DATE
  FILE
  ADVANCED
}

enum ValidationType {
  REQUIRED
  MIN_LENGTH
  MAX_LENGTH
  MIN_VALUE
  MAX_VALUE
  PATTERN
  EMAIL
  URL
  PHONE
  CUSTOM
}

enum SLAPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model FieldType {
  id          String        @id @default(uuid())
  name        String        @unique
  label       String
  category    FieldCategory
  description String?
  icon        String?

  hasOptions      Boolean @default(false)
  allowMultiple   Boolean @default(false)
  hasPlaceholder  Boolean @default(true)
  hasDefaultValue Boolean @default(true)

  availableValidations Json?

  componentType String
  inputProps    Json?

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("field_types")
}

model ValidationRuleCatalog {
  id          String         @id @default(uuid())
  type        ValidationType @unique
  name        String
  description String?

  requiresValue Boolean @default(false)
  valueType     String?

  defaultErrorMessage String @map("default_error_message")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("validation_rules_catalog")
}

model SLAConfiguration {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  priority    SLAPriority @default(MEDIUM)

  responseTime   Int @map("response_time")
  resolutionTime Int @map("resolution_time")

  escalationEnabled Boolean @default(false) @map("escalation_enabled")
  escalationTime    Int?    @map("escalation_time")

  businessHoursOnly Boolean @default(true) @map("business_hours_only")

  notifyOnBreach Boolean @default(true) @map("notify_on_breach")
  notifyBefore   Int?    @default(30) @map("notify_before")

  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  departments DepartmentSLA[]

  @@map("sla_configurations")
}

model DepartmentSLA {
  id                 String      @id @default(uuid())
  departmentId       String      @map("department_id")
  slaConfigurationId String      @map("sla_configuration_id")
  priority           SLAPriority
  isDefault          Boolean     @default(false) @map("is_default")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  slaConfiguration SLAConfiguration @relation(fields: [slaConfigurationId], references: [id], onDelete: Cascade)

  @@unique([departmentId, priority])
  @@map("department_sla")
}
