# ==============================================
# VARIABLES DE ENTORNO - SISTEMA DE TICKETS
# ==============================================

# ==============================================
# BASE DE DATOS
# ==============================================
DATABASE_URL="postgresql://usuario:password@localhost:5432/tiket_db?schema=public"

# ==============================================
# REDIS (Cache y Colas)
# ==============================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ==============================================
# SERVIDOR
# ==============================================
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
API_BASE_URL="http://localhost:3000"

# ==============================================
# SEGURIDAD Y AUTENTICACIÓN
# ==============================================
# JWT Secrets (generar con: openssl rand -base64 32)
JWT_SECRET="tu-jwt-secret-super-seguro-cambiar-en-produccion"
JWT_REFRESH_SECRET="tu-refresh-secret-super-seguro-cambiar-en-produccion"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Session
SESSION_TIMEOUT_HOURS=24
MAX_LOGIN_ATTEMPTS=5

# CORS
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# GOOGLE OAUTH
# ==============================================
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ==============================================
# EMAIL (SMTP)
# ==============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="tu-app-password"
EMAIL_FROM="Sistema de Tickets <noreply@tudominio.com>"

# ==============================================
# FIREBASE CLOUD MESSAGING (Push Notifications)
# ==============================================
FIREBASE_PROJECT_ID="tu-proyecto-firebase"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com"

# ==============================================
# ALMACENAMIENTO DE ARCHIVOS
# ==============================================
UPLOAD_DIR="/var/www/tiket/uploads"
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

# Imágenes
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=85

# ==============================================
# CONFIGURACIONES DEL SISTEMA
# ==============================================
# Tickets
AUTO_CLOSE_DAYS=7
TICKET_NUMBER_PADDING=3

# SLA por defecto (en horas)
SLA_LOW_HOURS=72
SLA_MEDIUM_HOURS=24
SLA_HIGH_HOURS=8
SLA_URGENT_HOURS=2
SLA_WARNING_THRESHOLD=80

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL="info"
LOG_FILE_PATH="./logs"
LOG_MAX_FILES=30
LOG_MAX_SIZE="20m"

# ==============================================
# MONITOREO Y ERRORES
# ==============================================
# Sentry (opcional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ==============================================
# WEBHOOKS
# ==============================================
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_RETRY_ATTEMPTS=3

# ==============================================
# BULL (Colas de Jobs)
# ==============================================
BULL_BOARD_ENABLED=true
BULL_BOARD_PATH="/admin/queues"

# ==============================================
# SWAGGER/API DOCS
# ==============================================
SWAGGER_ENABLED=true
SWAGGER_PATH="/api-docs"

# ==============================================
# BACKUP
# ==============================================
BACKUP_DIR="/var/backups/tiket"
BACKUP_RETENTION_DAYS_DB=30
BACKUP_RETENTION_DAYS_FILES=90

# ==============================================
# DESARROLLO (solo en dev)
# ==============================================
DEBUG=false
PRISMA_LOGGING=false
